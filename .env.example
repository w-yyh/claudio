# Claudio — AI DJ Server

# === AI ===
CLAUDE_API_KEY=sk-ant-...

# === TTS ===
FISH_AUDIO_KEY=your_fish_audio_key
# Fish Audio voice model reference ID (get from fish.audio dashboard)
FISH_AUDIO_REFERENCE_ID=

# === Music ===
# Local NeteaseCloudMusicApi instance — start separately with: npx NeteaseCloudMusicApi
NETEASE_API_URL=http://localhost:3000

# === Weather ===
WEATHER_API_KEY=your_openweather_key
WEATHER_CITY=Beijing

# === Server ===
PORT=4000
