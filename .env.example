# Claudio — AI DJ Server

# === LLM (OpenAI 兼容格式) ===
# DeepSeek / OpenAI / Groq / Ollama 等
LLM_API_KEY=sk-your-api-key
LLM_API_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# === TTS (可选，不填则用默认文字) ===
FISH_AUDIO_KEY=
FISH_AUDIO_REFERENCE_ID=

# === 网易云音乐 ===
# 启动方式: npx NeteaseCloudMusicApi
NETEASE_API_URL=http://localhost:3000
# Cookie 用于个性化推荐和听歌数据（浏览器 F12 → Cookies → MUSIC_U）
NETEASE_COOKIE=

# === 天气 ===
WEATHER_API_KEY=
WEATHER_CITY=Beijing

# === 日程 (滴答清单，可选) ===
# 获取方式: 网页版 → 头像 → 设置 → 账户与安全 → API 口令
TICKTICK_API_TOKEN=
TICKTICK_MCP_URL=https://mcp.dida365.com

# === 服务器 ===
PORT=4000
